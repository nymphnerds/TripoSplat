{
  "manifest_version": 1,
  "id": "triposplat",
  "name": "TripoSplat",
  "short_name": "TS",
  "version": "0.1.11",
  "description": "TripoSplat generates Gaussian splats from a single image and previews .ply / .splat outputs in the Manager.",
  "category": "3d",
  "kind": "3d",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/TripoSplat.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/TripoSplat.git",
    "ref": "main"
  },
  "overview": {
    "body": "TripoSplat converts a single source image into 3D Gaussian splats. This Nymph module installs the TripoSplat runtime, provides a Nymphs-native Manager UI, and saves .ply / .splat outputs under the shared Nymphs data root.\n\nInstall sets up the Python runtime only. Fetch Models downloads the VAST-AI/TripoSplat checkpoint bundle into $HOME/NymphsData/models/triposplat/ckpts.\n\nThis first TripoSplat module is a splat generator and previewer. It does not claim GLB, OBJ, or game-mesh export support.",
    "links": [
      {
        "label": "Nymphs TripoSplat fork",
        "url": "https://github.com/nymphnerds/TripoSplat"
      },
      {
        "label": "Upstream TripoSplat",
        "url": "https://github.com/VAST-AI-Research/TripoSplat"
      },
      {
        "label": "TripoSplat models",
        "url": "https://huggingface.co/VAST-AI/TripoSplat"
      },
      {
        "label": "Spark viewer",
        "url": "https://github.com/sparkjsdev/spark"
      }
    ],
    "requirements": [
      "Python 3 in the managed NymphsCore WSL distro",
      "CUDA 13 / PyTorch cu130 capable NVIDIA GPU",
      "TripoSplat model files fetched from Hugging Face"
    ]
  },
  "install": {
    "root": "$HOME/TripoSplat",
    "entrypoint": "scripts/install_triposplat.sh",
    "version_marker": "$HOME/TripoSplat/.nymph-module-version",
    "installed_markers": [
      "$HOME/TripoSplat/.nymph-module-version"
    ]
  },
  "runtime": {
    "host": "127.0.0.1",
    "port": 7002,
    "health_url": "http://127.0.0.1:7002/health",
    "server_info_url": "http://127.0.0.1:7002/server_info",
    "frontend_url": "http://127.0.0.1:7002/nymph"
  },
  "artifacts": {
    "models_root": "$HOME/NymphsData/models/triposplat",
    "cache_root": "$HOME/NymphsData/cache/triposplat",
    "outputs_root": "$HOME/NymphsData/outputs/triposplat",
    "logs_root": "$HOME/NymphsData/logs/triposplat",
    "config_root": "$HOME/NymphsData/config/triposplat",
    "huggingface_cache": "$HOME/NymphsData/cache/huggingface"
  },
  "entrypoints": {
    "install": "scripts/install_triposplat.sh",
    "update": "scripts/triposplat_update.sh",
    "status": "scripts/triposplat_status.sh",
    "start": "scripts/triposplat_start.sh",
    "stop": "scripts/triposplat_stop.sh",
    "kill": "scripts/triposplat_stop.sh",
    "open": "scripts/triposplat_open.sh",
    "open_nymph_ui": "scripts/triposplat_nymph_ui.sh",
    "logs": "scripts/triposplat_logs.sh",
    "fetch_models": "scripts/triposplat_fetch_models.sh",
    "smoke_test": "scripts/triposplat_smoke_test.sh",
    "uninstall": "scripts/triposplat_uninstall.sh",
    "open_weights": "scripts/triposplat_open_weights.sh",
    "open_outputs": "scripts/triposplat_open_outputs.sh"
  },
  "ui": {
    "sort_order": 48,
    "standard_lifecycle_rail": true,
    "manager_ui": {
      "type": "local_url",
      "title": "TripoSplat",
      "url": "http://127.0.0.1:7002/nymph",
      "requires_running": true,
      "start_action": "open_nymph_ui",
      "stop_action": "stop"
    },
    "manager_action_groups": [
      {
        "id": "model_fetch",
        "title": "Model Fetch",
        "layout": "compact",
        "entrypoint": "fetch_models",
        "result": "show_logs",
        "visibility": "installed",
        "description": "Install sets up the TripoSplat runtime only. Fetch Models downloads the VAST-AI/TripoSplat checkpoint bundle used for .ply and .splat generation.",
        "links": [
          {
            "label": "TripoSplat models",
            "url": "https://huggingface.co/VAST-AI/TripoSplat"
          }
        ],
        "fields": [
          {
            "name": "hf_token",
            "type": "secret",
            "label": "Hugging Face token",
            "secret_id": "huggingface.token",
            "env": "NYMPHS3D_HF_TOKEN",
            "optional": true
          }
        ],
        "submit": {
          "label": "Fetch Models"
        }
      }
    ],
    "manager_actions": [
      {
        "id": "open_nymph_ui",
        "label": "Open UI",
        "entrypoint": "open_nymph_ui",
        "result": "open_in_manager"
      },
      {
        "id": "smoke_test",
        "label": "Smoke Test",
        "entrypoint": "smoke_test",
        "result": "show_output"
      },
      {
        "id": "open_weights",
        "label": "Open Weights",
        "entrypoint": "open_weights",
        "result": "open_directory"
      },
      {
        "id": "open_outputs",
        "label": "Open Outputs",
        "entrypoint": "open_outputs",
        "result": "open_directory"
      },
      {
        "id": "logs",
        "label": "Logs",
        "entrypoint": "logs",
        "result": "open_notepad"
      }
    ]
  },
  "uninstall": {
    "supports_purge": true,
    "supports_data_delete": true,
    "requires_confirmation": true,
    "dry_run_arg": "--dry-run",
    "confirm_arg": "--yes",
    "purge_arg": "--purge",
    "data_only_arg": "--data-only",
    "preserve_by_default": [
      "outputs",
      "logs",
      "config",
      "model files",
      "Hugging Face cache"
    ],
    "removes_by_default": [
      "TripoSplat module source files",
      "TripoSplat Python venv"
    ]
  },
  "notes": [
    "Upstream Gradio remains reference/debug only; Manager opens the Nymphs TripoSplat UI.",
    "The module supports .ply and .splat outputs first.",
    "No GLB, OBJ, or game-mesh export support is claimed in this module version."
  ]
}
